# SONICA Audio Recognition Environment Variables
# Copy this file to .env and update the values

# Server Configuration
HOST=127.0.0.1
PORT=8080
RUST_LOG=info

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sonica_audio_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=sonica-audio-files

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRATION_HOURS=24

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@sonica.com

# Application Configuration
APP_NAME=SONICA Audio Recognition
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Security
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Audio Processing Configuration
MAX_AUDIO_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_AUDIO_FORMATS=wav,mp3,flac,m4a,aac,ogg
AUDIO_UPLOAD_PATH=./uploads/audio
TEMP_AUDIO_PATH=./temp/audio

# Machine Learning Model Configuration
MODEL_PATH=./models
DEFAULT_MODEL_NAME=whisper-base
DEFAULT_LANGUAGE=en-US
CONFIDENCE_THRESHOLD=0.5

# Audio Processing Settings
SAMPLE_RATE=16000
CHANNELS=1
BIT_DEPTH=16
MAX_AUDIO_DURATION=300  # 5 minutes in seconds

# External API Configuration (Optional)
OPENAI_API_KEY=your_openai_api_key
GOOGLE_SPEECH_API_KEY=your_google_speech_api_key
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=your_azure_region

# Processing Queue Configuration
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=300
CLEANUP_TEMP_FILES_AFTER_HOURS=24

# Monitoring and Logging
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=info
LOG_FORMAT=json
