# SONICA Audio Recognition Environment Variables
# Copy this file to .env and update the values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Host address to bind the server to (0.0.0.0 for all interfaces)
HOST=0.0.0.0
# Port number for the HTTP server
PORT=3000
# Log level (trace, debug, info, warn, error)
LOG_LEVEL=info

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://sonica_user:sonica_pass@localhost:5432/sonica_db
# Maximum number of database connections in the pool
DATABASE_MAX_CONNECTIONS=10
# Timeout in seconds for acquiring a database connection
DATABASE_ACQUIRE_TIMEOUT=30

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection string for caching and session storage
REDIS_URL=redis://localhost:6379
# Maximum number of Redis connections in the pool
REDIS_MAX_CONNECTIONS=10
# Timeout in seconds for Redis connection
REDIS_CONNECTION_TIMEOUT=5

# =============================================================================
# CLOUDFLARE R2 STORAGE CONFIGURATION (Optional)
# =============================================================================
# R2 endpoint URL (e.g., https://your-account-id.r2.cloudflarestorage.com)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2 access key ID
R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2 secret access key
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2 bucket name for storing audio files
R2_BUCKET_NAME=sonica-audio-files
# R2 region (usually auto)
R2_REGION=auto

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT secret key for authentication (use a strong, random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=60
# Rate limiting: requests per minute per IP
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allowed origins for CORS (comma-separated, use * for all)
CORS_ORIGINS=*
# Whether to allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=false

# =============================================================================
# AUDIO PROCESSING CONFIGURATION
# =============================================================================
# Maximum audio file size in bytes (50MB)
MAX_AUDIO_FILE_SIZE=52428800
# Comma-separated list of allowed audio formats
ALLOWED_AUDIO_FORMATS=wav,mp3,flac,m4a,aac,ogg
# Local directory for audio file uploads
AUDIO_UPLOAD_PATH=./uploads/audio
# Temporary directory for audio processing
TEMP_AUDIO_PATH=./temp/audio

# =============================================================================
# MACHINE LEARNING MODEL CONFIGURATION
# =============================================================================
# Directory containing ML models
MODEL_PATH=./models
# Default model name for audio recognition
DEFAULT_MODEL_NAME=whisper-base
# Default language for recognition (ISO 639-1 code)
DEFAULT_LANGUAGE=en-US
# Minimum confidence threshold for recognition results (0.0-1.0)
CONFIDENCE_THRESHOLD=0.5

# =============================================================================
# AUDIO PROCESSING SETTINGS
# =============================================================================
# Audio sample rate in Hz
SAMPLE_RATE=16000
# Number of audio channels (1=mono, 2=stereo)
CHANNELS=1
# Audio bit depth
BIT_DEPTH=16
# Maximum audio duration in seconds (5 minutes)
MAX_AUDIO_DURATION=300

# =============================================================================
# EXTERNAL API CONFIGURATION (Optional)
# =============================================================================
# OpenAI API key for advanced speech recognition
OPENAI_API_KEY=your_openai_api_key
# Google Speech-to-Text API key
GOOGLE_SPEECH_API_KEY=your_google_speech_api_key
# Azure Speech Services key
AZURE_SPEECH_KEY=your_azure_speech_key
# Azure Speech Services region
AZURE_SPEECH_REGION=your_azure_region

# =============================================================================
# PROCESSING QUEUE CONFIGURATION
# =============================================================================
# Maximum number of concurrent audio processing jobs
MAX_CONCURRENT_JOBS=5
# Timeout in seconds for processing jobs
JOB_TIMEOUT_SECONDS=300
# Hours after which temporary files are cleaned up
CLEANUP_TEMP_FILES_AFTER_HOURS=24
